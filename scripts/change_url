#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# BACK UP THE CURRENT CONFIG AND STOP SERVICE
#=================================================
ynh_script_progression "Backing up the current configuration before URL change..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# RE-APPLY NGINX WITH THE NEW DOMAIN/PATH
#=================================================
ynh_script_progression "Updating NGINX configuration..."

# YunoHost sets $new_domain and $new_path before calling this script
domain=$new_domain
path=$new_path

ynh_config_add_nginx

#=================================================
# UPDATE SSOwat PERMISSION URL
#=================================================
ynh_permission_url --permission="main" \
    --add_url="$new_domain$new_path" \
    --remove_url="$old_domain$old_path"

#=================================================
# RESTART SERVICE
#=================================================
ynh_script_progression "Restarting $app's systemd service..."

# NOTE: --wait_until is intentionally omitted — see install script comment.
ynh_systemctl --service="$app" --action="start" --log_path="systemd"

ynh_systemctl --service=nginx --action=reload

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Change of URL completed for $app"
