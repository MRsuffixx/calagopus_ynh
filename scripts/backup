#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

# NOTE: backup/restore scripts must source from ../settings/scripts/
source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

ynh_print_info "Declaring files to be backed up..."

# NOTE: We do NOT back up $install_dir because this is an APT-managed
# installation. The calagopus-panel binary lives at /usr/bin/calagopus-panel
# and will be re-installed from the APT repository during restore.

#=================================================
# BACKUP THE CALAGOPUS CONFIGURATION DIRECTORY
#=================================================

# /etc/$app/.env contains DATABASE_URL, APP_ENCRYPTION_KEY, and all env vars.
# This is the most critical file — losing it means losing the encryption key.
ynh_backup "$calagopus_conf_dir"

#=================================================
# BACKUP SYSTEM CONFIGURATION
#=================================================

# NGINX configuration
ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"

# systemd service unit
ynh_backup "/etc/systemd/system/$app.service"

# logrotate configuration
ynh_backup "/etc/logrotate.d/$app"

# APT repository source and keyring (needed to reinstall the package on restore)
ynh_backup "/etc/apt/sources.list.d/calagopus.list"
ynh_backup "/usr/share/keyrings/calagopus-archive-keyring.gpg"

#=================================================
# BACKUP THE POSTGRESQL DATABASE
#=================================================
ynh_print_info "Backing up the PostgreSQL database..."

ynh_psql_dump_db > db.sql

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will then actually copy those files to the archive)."
