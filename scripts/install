#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

# Settings automatically loaded as bash variables:
#   $domain, $path, $port, $app
#   $db_name, $db_user, $db_pwd  (from [resources.database] postgresql)

#=================================================
# ADD THE CALAGOPUS APT REPOSITORY
#=================================================
ynh_script_progression "Adding the Calagopus APT repository..."

# Import the signing key
curl -fsSL https://packages.calagopus.com/pub.gpg \
    -o /usr/share/keyrings/calagopus-archive-keyring.gpg

# Add the repository source
echo "deb [signed-by=/usr/share/keyrings/calagopus-archive-keyring.gpg] https://packages.calagopus.com/deb stable main" \
    | tee /etc/apt/sources.list.d/calagopus.list

apt-get update -qq

#=================================================
# INSTALL CALAGOPUS PANEL FROM APT
#=================================================
ynh_script_progression "Installing calagopus-panel from APT repository..."

# Stop the package's auto-started service (if the APT package starts one) so
# it does not conflict with the YunoHost-managed unit we create below.
if systemctl is-active --quiet calagopus-panel.service 2>/dev/null; then
    systemctl stop calagopus-panel.service || true
    systemctl disable calagopus-panel.service || true
fi

DEBIAN_FRONTEND=noninteractive apt-get install -y calagopus-panel

#=================================================
# CONFIGURE POSTGRESQL DATABASE
#=================================================
ynh_script_progression "Configuring the PostgreSQL database..."

# [resources.database] type="postgresql" auto-provisions $db_name/$db_user/$db_pwd.
# Persist the password explicitly so upgrade/restore can retrieve it.
ynh_app_setting_set --key=db_pwd --value="$db_pwd"

#=================================================
# CREATE ENVIRONMENT CONFIGURATION
#=================================================
ynh_script_progression "Creating $app environment configuration..."

mkdir -p "$calagopus_conf_dir"

# Generate a secure 32-character encryption key
app_encryption_key=$(ynh_string_random --length=32)
ynh_app_setting_set --key=app_encryption_key --value="$app_encryption_key"

# Render the .env template into /etc/$app/.env
ynh_config_add --template="env" --destination="$calagopus_conf_dir/.env"

# Lock down the config file: it contains secrets
chmod 600 "$calagopus_conf_dir/.env"
chown "$app:$app" "$calagopus_conf_dir/.env"

#=================================================
# NGINX CONFIGURATION
#=================================================
ynh_script_progression "Configuring NGINX web server..."

ynh_config_add_nginx

#=================================================
# SETUP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

ynh_config_add_systemd

yunohost service add "$app" \
    --description="Calagopus game server management panel" \
    --log="/var/log/$app/$app.log"

#=================================================
# SETUP LOGROTATE
#=================================================
ynh_script_progression "Configuring log rotation..."

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

# NOTE: --wait_until is intentionally omitted because we cannot guarantee the
# exact log string Calagopus emits on startup. ynh_systemctl will start the
# service and verify it is in an active state after launch.
ynh_systemctl --service="$app" --action="start" --log_path="systemd"

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Installation of $app completed"
